# Application mode: development, testing, or production
FLASK_ENV=development
SECRET_KEY=replace-with-at-least-32-random-characters

# Development defaults to instance/smart_health.db. Production must use PostgreSQL.
DATABASE_URL=postgresql+psycopg://smarthealth:change-me@db:5432/smarthealth
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
RATELIMIT_STORAGE_URI=redis://redis:6379/0
PRIVATE_UPLOAD_ROOT=/var/lib/smarthealth/private_uploads
MAX_UPLOAD_MB=8
SESSION_MINUTES=30
TRUST_PROXY_HEADERS=true
SEED_REFERENCE_DATA=true

# Emergency alerts. Twilio sender must be an E.164 phone number or approved messaging service.
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_FROM=+15551234567
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token

# Only used by explicit development seeding; rotate immediately outside local demos.
DEMO_PASSWORD=DemoPatient!2026
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!Admin2026

# Gunicorn
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=60
